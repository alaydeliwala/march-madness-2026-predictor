    {
      "id": "t_43",
      "type": "text",
      "x": 630,
      "y": 455.75,
      "width": 320,
      "height": 165.0,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
