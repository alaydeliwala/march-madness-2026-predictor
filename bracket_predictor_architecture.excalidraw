    {
      "id": "t_60",
      "type": "text",
      "x": 630,
      "y": 715,
      "width": 625,
      "height": 210.0,
      "angle": 0,
      "strokeColor": "#1e1e1e",
      "backgroundColor": "transparent",
      "fillStyle": "solid",
      "strokeWidth": 1,
      "strokeStyle": "solid",
      "roughness": 0,
      "opacity": 100,
      "groupIds": [],
      "frameId": null,
      "roundness": null,
      "seed": 421,
      "version": 1,
      "versionNonce": 781,
      "isDeleted": false,
      "boundElements": null,
      "updated": 1710700000000,
      "link": null,
      "locked": false,
      "text": "POOL VALUE OPTIMIZER (KEY FOR WINNING POOLS)\n\nUpset Budget per round:\n  R64: max 4 | R32: max 2 | S16: max 1 | E8: max 1\n\nUpset Selection Criteria (seed-specific):\n  6v11: model prob >= 44%  (historical upset rate: 50%!)\n  7v10: model prob >= 46%  (historical upset rate: 37%)\n  5v12: model prob >= 40%  (historical upset rate: 40%)\n  4v13: model prob >= 38%  (rarer, high leverage)\n  R32+: prob >= 46%, composite within 0.8 std dev\n\nLeverage = P(win) x Round Points / Est. Public Pick Rate\nPick upset when: leverage(upset) > leverage(chalk) AND thresholds met",
      "fontSize": 12,
      "fontFamily": 3,
      "textAlign": "left",
      "verticalAlign": "top",
      "containerId": "r_59",
      "originalText": "POOL VALUE OPTIMIZER (KEY FOR WINNING POOLS)\n\nUpset Budget per round:\n  R64: max 4 | R32: max 2 | S16: max 1 | E8: max 1\n\nUpset Selection Criteria (seed-specific):\n  6v11: model prob >= 44%  (historical upset rate: 50%!)\n  7v10: model prob >= 46%  (historical upset rate: 37%)\n  5v12: model prob >= 40%  (historical upset rate: 40%)\n  4v13: model prob >= 38%  (rarer, high leverage)\n  R32+: prob >= 46%, composite within 0.8 std dev\n\nLeverage = P(win) x Round Points / Est. Public Pick Rate\nPick upset when: leverage(upset) > leverage(chalk) AND thresholds met",
      "autoResize": true,
      "lineHeight": 1.25
    },
